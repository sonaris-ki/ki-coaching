<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sonaris – Die drei Säulen unserer Leistung</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #0C121A;
    color: #A0B9D7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48px 24px;
  }

  .logo-bar {
    position: fixed;
    top: 28px;
    left: 32px;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo-mark {
    width: 32px;
    height: 32px;
  }
  .logo-text {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #C8DCF0;
  }

  .header {
    text-align: center;
    margin-bottom: 64px;
    max-width: 760px;
    margin-top: 32px;
  }
  .eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #6E91B4;
    margin-bottom: 16px;
  }
  h1 {
    font-size: 38px;
    font-weight: 700;
    line-height: 1.2;
    color: #C8DCF0;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }
  .subtitle {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #A0B9D7;
    max-width: 620px;
    margin: 0 auto;
    opacity: 0.8;
  }
  .anchor {
    display: inline-block;
    margin-top: 28px;
    background: rgba(110,145,180,0.06);
    border: 1px solid rgba(110,145,180,0.2);
    border-radius: 12px;
    padding: 16px 28px;
    font-size: 15px;
    font-weight: 500;
    color: #B4C8E1;
    line-height: 1.6;
    max-width: 680px;
    text-align: center;
  }

  .columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1100px;
    width: 100%;
    margin-bottom: 56px;
  }
  .card {
    background: #151D28;
    border: 1px solid rgba(110,145,180,0.12);
    border-radius: 20px;
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .card:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    border-radius: 20px 20px 0 0;
  }
  .card::after {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 160px; height: 160px;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 70%);
    pointer-events: none;
  }
  .card-1 { --accent: #6E91B4; --accent-soft: rgba(110,145,180,0.08); }
  .card-2 { --accent: #3B82F6; --accent-soft: rgba(59,130,246,0.08); }
  .card-3 { --accent: #AA7D55; --accent-soft: rgba(170,125,85,0.08); }

  .card-icon {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: var(--accent-soft);
    border: 1px solid rgba(110,145,180,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .card-icon svg {
    width: 48px;
    height: 48px;
  }
  .card-number {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .card-title {
    font-size: 20px;
    font-weight: 700;
    color: #C8DCF0;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .card-subtitle {
    font-size: 13px;
    color: #8CA0BE;
    margin-bottom: 24px;
    font-weight: 400;
    line-height: 1.5;
  }
  .divider {
    height: 1px;
    background: rgba(110,145,180,0.1);
    margin-bottom: 24px;
  }
  .items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .items li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: #A0B9D7;
    line-height: 1.5;
  }
  .items li::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 6px;
    flex-shrink: 0;
  }

  .examples-section {
    max-width: 1100px;
    width: 100%;
    margin-bottom: 56px;
  }
  .examples-header {
    text-align: center;
    margin-bottom: 32px;
  }
  .examples-header h2 {
    font-size: 22px;
    font-weight: 700;
    color: #C8DCF0;
    margin-bottom: 8px;
  }
  .examples-header p {
    font-size: 14px;
    color: #8CA0BE;
  }
  .examples-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .example-card {
    background: #151D28;
    border: 1px solid rgba(110,145,180,0.12);
    border-radius: 14px;
    padding: 24px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    transition: border-color 0.3s ease;
  }
  .example-card:hover {
    border-color: rgba(110,145,180,0.3);
  }
  .example-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .example-icon svg {
    width: 48px;
    height: 48px;
  }
  .example-content h3 {
    font-size: 15px;
    font-weight: 600;
    color: #C8DCF0;
    margin-bottom: 6px;
  }
  .example-content p {
    font-size: 13px;
    color: #8CA0BE;
    line-height: 1.6;
  }
  .example-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }
  .tag {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(110,145,180,0.08);
    color: #6E91B4;
    border: 1px solid rgba(110,145,180,0.15);
  }

  .footer-note {
    text-align: center;
    max-width: 620px;
    font-size: 13px;
    color: #8CA0BE;
    line-height: 1.7;
    border-top: 1px solid rgba(110,145,180,0.1);
    padding-top: 32px;
    margin-top: 8px;
    opacity: 0.7;
  }
  .logo-footer {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(110,145,180,0.25);
    margin-top: 24px;
  }

  @media (max-width: 900px) {
    .columns { grid-template-columns: 1fr; }
    .examples-grid { grid-template-columns: 1fr; }
    h1 { font-size: 28px; }
  }
</style>
</head>
<body>

<div class="logo-bar">
  <svg class="logo-mark" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
    <circle cx="60" cy="60" r="40" fill="rgba(110,145,180,0.04)"/>
